<!DOCTYPE html>
<html>
<head>
  <title>Users</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <h1>Users</h1>
  <a href="/dashboard">Dashboard</a>

  <table border="1" cellpadding="8">
    <tr>
      <th>Chat ID</th>
      <th>Username</th>
      <th>Ism</th>
      <th>Balance</th>
      <th>Top up</th>
    </tr>

    <% users.forEach(user => { %>
      <tr>
        <td><%= user.chat_id %></td>
        <td>@<%= user.username || "" %></td>
        <td><%= (user.first_name || "") %> <%= (user.last_name || "") %></td>
        <td><%= user.balance %></td>
        <td>
          <form method="POST" action="/users/<%= user.chat_id %>/balance">
            <input type="number" step="0.01" name="amount" placeholder="summa">
            <button type="submit">Qo‘shish</button>
          </form>
        </td>
      </tr>
    <% }) %>
  </table>
</body>
</html>
